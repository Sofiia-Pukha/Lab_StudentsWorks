@model IEnumerable<WebMVC.Domain.Entities.Teacher>

@{
    ViewData["Title"] = "Список викладачів";
}

<div class="container mt-4">
    <h1 class="mb-4">Викладачі</h1>

    <p>
        <a asp-action="Create" class="btn btn-primary">Додати викладача</a>
    </p>

    <table class="table table-bordered table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ПІБ Викладача</th>
                <th>Кафедра</th>
                <th style="width: 250px;">Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="align-middle">@item.FullName</td>
                    <td class="align-middle">
                        @if (item.Department != null)
                        {
                            <span class="badge bg-info text-dark">@item.Department.Name</span>
                        }
                        else
                        {
                            <span class="text-muted">Не закріплено</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редагувати</a>
                        
                        <a asp-action="Delete" asp-route-id="@item.Id" 
                           class="btn btn-sm btn-danger" 
                           onclick="return confirm('Ви впевнені, що хочете видалити викладача @item.FullName?');">
                            Видалити
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>