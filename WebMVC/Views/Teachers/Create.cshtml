@model WebMVC.Domain.Entities.Teacher

<h1>Додати викладача</h1>
<form asp-action="Create">
    <div class="form-group">
        <label>Повне ім'я</label>
        <input asp-for="FullName" class="form-control" />
    </div>
    <div class="form-group mt-3">
        <label>Кафедра</label>
        <select asp-for="DepartmentId" class="form-control" asp-items="ViewBag.Departments"></select>
    </div>
    <button type="submit" class="btn btn-success mt-3">Зберегти</button>
</form>
