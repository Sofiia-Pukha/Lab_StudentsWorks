@model WebMVC.Domain.Entities.Department

<div class="container">
    <h1>Додати кафедру</h1>
    <hr />
    <div class="row">
        <div class="col-md-4">
            <form asp-action="Create">
                <div class="form-group">
                    <label class="control-label">Назва кафедри</label>
                    <input asp-for="Name" class="form-control" placeholder="Введіть назву..." />
                </div>
                <div class="form-group mt-3">
                    <input type="submit" value="Зберегти" class="btn btn-success" />
                    <a asp-action="Index" class="btn btn-secondary">Назад до списку</a>
                </div>
            </form>
        </div>
    </div>
</div>