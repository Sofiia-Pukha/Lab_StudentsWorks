@model IEnumerable<WebMVC.Domain.Entities.Review>

@{
    ViewData["Title"] = "Відгуки студентів";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Відгуки про викладачів</h1>
</div>

<div class="row">
    @foreach (var item in Model) {
        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm border-warning">
                <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                    <strong class="fs-5">@item.Teacher?.FullName</strong>
                    <span class="badge bg-dark fs-6">⭐ @item.Rating / 5</span>
                </div>
                <div class="card-body">
                    <p class="card-text fs-5">"@item.Comment"</p>
                </div>
                <div class="card-footer bg-white">
                    <div class="text-muted small mb-2">
                        <strong>Тема роботи:</strong> <em>@item.Work?.Title</em> <br/>
                        <strong>Студент:</strong> @(item.Student?.Username ?? "Анонім")
                    </div>

                    @if (User.IsInRole("Admin"))
                    {
                        <div class="border-top pt-2 d-flex justify-content-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" 
                               class="btn btn-sm btn-outline-warning me-2">Редагувати</a>
                            
                            <a asp-action="Delete" asp-route-id="@item.Id" 
                               class="btn btn-sm btn-outline-danger" 
                               onclick="return confirm('Ви впевнені, що хочете видалити цей відгук?');">
                               Видалити
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>