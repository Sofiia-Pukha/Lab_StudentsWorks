@model IEnumerable<WebMVC.Domain.Entities.Work>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Каталог студентських робіт</h1>
    <a asp-action="Create" class="btn btn-primary">+ Поділитися своєю роботою</a>
</div>

<form asp-action="Index" method="get" class="mb-4 p-3 bg-light rounded shadow-sm border border-light">
    <div class="row g-2">
        <div class="col-md-3">
            <input type="text" name="searchString" value="@ViewBag.CurrentSearch" class="form-control" placeholder="Пошук за назвою..." />
        </div>
        
        <div class="col-md-2">
            <select name="categoryId" class="form-select" asp-items="ViewBag.Categories">
                <option value="">Усі тематики</option>
            </select>
        </div>

        <div class="col-md-3">
            <select name="departmentId" class="form-select" asp-items="ViewBag.Departments">
                <option value="">Усі кафедри</option>
            </select>
        </div>

        <div class="col-md-2">
            <select name="teacherId" class="form-select" asp-items="ViewBag.Teachers">
                <option value="">Усі викладачі</option>
            </select>
        </div>

        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-primary w-100">Шукати</button>
            <a asp-action="Index" class="btn btn-secondary w-100">Скинути</a>
        </div>
    </div>
</form>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Тема</th>
            <th>Студент</th>
            <th>Категорія</th>
            <th>Викладач</th>
            <th>Бал</th>
            <th>Рік</th>
            <th>Файл</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Any()) {
            @foreach (var item in Model) {
                <tr>
                    <td class="fw-bold">@item.Title</td>
                    <td>@item.Student?.Username</td>
                    <td>@item.Category?.Name</td>
                    <td>@item.Teacher?.FullName</td>
                    <td>
                        @(item.Grade.HasValue ? item.Grade.ToString() : "-")
                    </td>
                    <td>@item.ExecutionYear</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.FileUrl)) {
                            <a href="@item.FileUrl" target="_blank" class="text-primary">Відкрити</a>
                        } else {
                            <span class="text-muted">Немає</span>
                        }
                    </td>
                </tr>
            }
        } else {
            <tr>
                <td colspan="7" class="text-center text-muted p-4">
                    За вашим запитом не знайдено жодної роботи 
                </td>
            </tr>
        }
    </tbody>
</table>